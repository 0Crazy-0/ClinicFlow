{
    "stryker-config": {
        "test-runner": "mtp",
        "project": "ClinicFlow.Infrastructure.csproj",
        "reporters": ["html", "dashboard", "progress"],
          "thresholds": {
            "high": 95,
            "low": 90,
            "break": 85
        },
        "project-info": {
            "name": "github.com/0Crazy-0/ClinicFlow",
            "module": "Infrastructure"
        },
        "mutate": [
            "!**/DependencyInjection.cs",
            "!**/Migrations/**",
            "!**/Configurations/**",
            "!**/ApplicationDbContextFactory.cs",
            "!**/ColumnNames.cs",
            "!**/Options/**",
            "!**/Seeding/**"
        ]
    }
}