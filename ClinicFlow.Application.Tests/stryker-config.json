{
    "stryker-config": {
        "test-runner": "mtp",
        "project": "ClinicFlow.Application.csproj",
        "reporters": ["html", "dashboard", "progress"],
          "thresholds": {
            "high": 95,
            "low": 90,
            "break": 80
        },
        "project-info": {
            "name": "github.com/0Crazy-0/ClinicFlow",
            "module": "Application"
        },
        "mutate": [
            "!**/DependencyInjection.cs",
            "!**/ValidationException.cs",
            "!**/DTOs/**",
            "!**/*Command.cs",
            "!**/*Query.cs"
        ]
    }
}